# =============================================================================
# Prompt Shield API Proxy - Environment Variables
# =============================================================================
# Copy this file to .env and customize the values
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------

# Enable/disable Prompt Shield globally
# Default: true
#PROMPT_SHIELD_ENABLED=true

# Hash algorithm for generating tags
# Options: SHA-256, SHA-512, MD5
# Default: SHA-256
#PROMPT_SHIELD_HASH_ALGORITHM=SHA-256

# Length of the generated hash (characters)
# Default: 6
#PROMPT_SHIELD_HASH_LENGTH=6

# Storage backend for obfuscation tags
# Options: memory, jpa, redis
# Default: memory
#PROMPT_SHIELD_STORAGE_TYPE=memory

# Prefix for redacted values in tags
# Default: REDACTED
#PROMPT_SHIELD_REDACTED_PREFIX=REDACTED

# Tag format: {tagOpen}{redactedPrefix}:{type}{tagSeparator}{hash}{tagClose}
# Example: ~REDACTED:DNI#1c9f96~

# Separator between type and hash
# Default: #
#PROMPT_SHIELD_TAG_SEPARATOR=#

# Opening character for tags
# Default: ~
#PROMPT_SHIELD_TAG_OPEN=~

# Closing character for tags
# Default: ~
#PROMPT_SHIELD_TAG_CLOSE=~

# -----------------------------------------------------------------------------
# Proxy Settings
# -----------------------------------------------------------------------------

# Enable/disable the proxy
# Default: true
#PROMPT_SHIELD_PROXY_ENABLED=true

# Base path for the API endpoints
# Default: /v1
#PROMPT_SHIELD_PROXY_BASE_PATH=/v1

# Inject obfuscation instructions into system messages
# Default: true
#PROMPT_SHIELD_PROXY_INJECT_SYSTEM_PROMPT=true

# Restore original values in AI responses
# Default: true
#PROMPT_SHIELD_PROXY_RESTORE_ON_RESPONSE=true

# -----------------------------------------------------------------------------
# Provider Settings (AI Backend)
# -----------------------------------------------------------------------------

# Base URL of the AI provider (OpenAI, Ollama, Azure, etc.)
# Default: https://api.openai.com
PROMPT_SHIELD_PROXY_PROVIDER_BASE_URL=https://api.openai.com

# API key for the AI provider
# Required: Yes (unless using local providers like Ollama)
PROMPT_SHIELD_PROXY_PROVIDER_API_KEY=your-api-key-here

# Model to use for chat completions
# Default: gpt-4o-mini
#PROMPT_SHIELD_PROXY_PROVIDER_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Examples for different providers
# -----------------------------------------------------------------------------

# --- OpenAI ---
#PROMPT_SHIELD_PROXY_PROVIDER_BASE_URL=https://api.openai.com
#PROMPT_SHIELD_PROXY_PROVIDER_API_KEY=sk-xxx
#PROMPT_SHIELD_PROXY_PROVIDER_MODEL=gpt-4o-mini

# --- Ollama (local) ---
#PROMPT_SHIELD_PROXY_PROVIDER_BASE_URL=http://ollama:11434
#PROMPT_SHIELD_PROXY_PROVIDER_API_KEY=not-needed
#PROMPT_SHIELD_PROXY_PROVIDER_MODEL=llama3

# --- Azure OpenAI ---
#PROMPT_SHIELD_PROXY_PROVIDER_BASE_URL=https://your-resource.openai.azure.com
#PROMPT_SHIELD_PROXY_PROVIDER_API_KEY=your-azure-key
#PROMPT_SHIELD_PROXY_PROVIDER_MODEL=gpt-4

# --- LM Studio (local) ---
#PROMPT_SHIELD_PROXY_PROVIDER_BASE_URL=http://host.docker.internal:1234
#PROMPT_SHIELD_PROXY_PROVIDER_API_KEY=not-needed
#PROMPT_SHIELD_PROXY_PROVIDER_MODEL=local-model

# --- vLLM (local) ---
#PROMPT_SHIELD_PROXY_PROVIDER_BASE_URL=http://host.docker.internal:8000
#PROMPT_SHIELD_PROXY_PROVIDER_API_KEY=not-needed
#PROMPT_SHIELD_PROXY_PROVIDER_MODEL=meta-llama/Llama-3-8B-Instruct

# -----------------------------------------------------------------------------
# Docker Compose Settings
# -----------------------------------------------------------------------------

# Port to expose the proxy
# Default: 8080
#PROXY_PORT=8080
